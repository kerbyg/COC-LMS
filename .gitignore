# Ignore XAMPP & local environment
/.vscode
/.idea
/.env
/config/email.local.php
/config/database.local.php

# Production DB credentials — never commit
/config/db.config.php

# Ignore database dumps
/database/*.sql

# Ignore one-time setup/seed scripts that may contain secrets
/setup_*.php
/seed_*.php
/database/migrations/add_*_key.sql
/database/migrations/add_*_api*.sql
/tools/student-login.json

# Ignore logs & cache
*.log
/tmp
/cache

# Ignore uploads
/uploads

# Ignore composer & node
/vendor
/node_modules
